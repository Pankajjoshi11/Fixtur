# The Transaction connection pooler string (used by Prisma Client)
# Notice the ?pgbouncer=true at the end
DATABASE_URL="postgresql://postgres.yourprojectid:your_actual_password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# The Session connection string (used for Prisma migrations)
# It uses port 5432 and does NOT have pgbouncer
DIRECT_URL="postgresql://postgres.yourprojectid:your_actual_password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# Pusher WebSocket Credentials
PUSHER_APP_ID="2163142"
NEXT_PUBLIC_PUSHER_KEY="1489763e561e84bb54fb"
PUSHER_SECRET="944444980ee4f348f331"
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"
